# CoinDCX API Credentials
COINDCX_API_KEY=
COINDCX_API_SECRET=

# Bot Configuration
# Comma separated pairs (e.g., B-BTC_USDT,B-ETH_USDT)
COINDCX_PAIRS=B-BTC_USDT,B-ETH_USDT

# Ollama (AI Strategy Pulse) — local daemon OR Ollama Cloud
# Local (default):
#   OLLAMA_URL=http://127.0.0.1:11434
#   OLLAMA_MODEL=llama3.1:8b
# Cloud (https://ollama.com — API key is REQUIRED, leave blank only for local):
#   OLLAMA_URL=https://ollama.com
#   OLLAMA_API_KEY=ollama_...   # from https://ollama.com/settings/keys
#   OLLAMA_MODEL=<id from `curl -s https://ollama.com/api/tags -H "Authorization: Bearer $KEY"`>
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gpt-oss:120b-cloud
OLLAMA_API_KEY=

# Local Ollama fallback — used automatically when the primary host (above) is
# unreachable or returns an availability error (5xx/401/network). Leave
# OLLAMA_FALLBACK_URL empty to disable failover.
OLLAMA_FALLBACK_URL=http://127.0.0.1:11434
OLLAMA_FALLBACK_MODEL=llama3

# Safety: Set to false only if you want to enable order execution (if implemented)
READ_ONLY=true

# Optional: Override Socket URL
COINDCX_SOCKET_URL=wss://stream.coindcx.com

# F1 Reliability Foundation
# Docker (this repo): host port 5433 → postgres://bot:bot@localhost:5433/coindcx_bot
# Native Postgres on this machine: postgres://bot:bot@localhost:5432/coindcx_bot
PG_URL=postgres://bot:bot@localhost:5432/coindcx_bot
LOG_DIR=./logs
LOG_LEVEL=info
LOG_FILE_ROTATE_MB=50
LOG_FILE_KEEP=10
SIGNAL_SINKS=stdout,file,telegram
SHUTDOWN_GRACE_MS=5000
AUDIT_BUFFER_MAX=10000
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_RATE_PER_MIN=20

# F3 Account reconciler — PnL loss alert vs position notional (WS position updates only)
# Ratio = unrealizedPnl / (avgPrice × |active_pos|). Alert when ratio < ACCOUNT_PNL_ALARM_PCT (more negative = stricter).
# Example: -0.08 warns when unrealized loss exceeds 8% of that notional. Default in code if unset: -0.10.
ACCOUNT_PNL_ALARM_PCT=-0.08
# Throttle repeat emits per key (e.g. position.pnl_threshold per id). Default if unset: 300000 (5 min).
ACCOUNT_SIGNAL_COOLDOWN_MS=120000

# F2 Market Data Integrity
RESYNC_WS_TIMEOUT_MS=3000
REST_BUDGET_TIMEOUT_MS=5000
REST_BUDGET_GLOBAL_PER_MIN=6
REST_BUDGET_PAIR_PER_MIN=1
HEARTBEAT_TIMEOUT_MS=35000
HEARTBEAT_INTERVAL_MS=15000
STALE_FLOOR_currentPrices=5000
STALE_FLOOR_newTrade=30000
STALE_FLOOR_depthUpdate=10000
CHECKSUM_INTERVAL_MS=30000
REST_CHECKSUM_INTERVAL_MS=600000
TIME_SYNC_INTERVAL_MS=900000
# Local vs exchange/NTP combined skew (ms); 2500 is safer on WSL / high RTT than 500
SKEW_THRESHOLD_MS=2500
TAIL_BUFFER_SIZE=1000
LATENCY_RESERVOIR=4096
STALE_RESERVOIR=1024
BOOK_INTEGRITY_MODE=heuristic

# Stateful liquidity raid engine (Fusion + OHLCV).
LIQUIDITY_ENGINE_ENABLED=true
LIQUIDITY_POOL_TIMEFRAME=15m
LIQUIDITY_VELOCITY_MIN_PCT_PER_SEC=0.10
LIQUIDITY_ACTIONABLE_SCORE_MIN=8
LIQUIDITY_WATCHLIST_SCORE_MIN=5
